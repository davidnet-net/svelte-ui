{
	"name": "svelte-ui",
	"version": "2.0.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/davidnet-net/svelte-ui.git"
	},
	"scripts": {
		"dev": "npm run paracompile && vite dev",
		"build": "npm run paracompile && vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "husky",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"fmt": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"lintfix": "prettier --write .&& eslint . --fix",
		"paracompile": "echo 'Compile paraglide thing' && paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide"
	},
	"lint-staged": {
		"**/*.{js,ts,svelte,json,css}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@inlang/paraglide-js": "^2.8.0",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^22",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"publint": "^0.3.15",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite": "^7.2.6"
	},
	"keywords": [
		"svelte"
	],
	"dependencies": {
		"@vanilla-extract/css": "^1.18.0",
		"@vanilla-extract/recipes": "^0.5.7",
		"@vanilla-extract/vite-plugin": "^5.1.4"
	}
}
