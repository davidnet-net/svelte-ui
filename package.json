{
	"name": "svelte-ui",
	"version": "2.0.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/davidnet-net/svelte-ui.git"
	},
	"license": "SEE LICENSE IN license",
	"private": "true",
	"scripts": {
		"setup": "bun meta/scripts/setup.ts",
		"dev": "bun run setup && bun x --bun vite dev --host",
		"build": "bun run setup && bun x --bun vite build && bun run prepack",
		"prepack": "bun x svelte-kit sync && bun x svelte-package && bun x publint",
		"fmt": "bun x prettier --write . && bun x eslint . --fix",
		"lint": "bun x prettier --check . && bun x eslint .",
		"prepare": "bun install && bun run build"
	},
	"lint-staged": {
		"**/*.{js,ts,svelte,json,css}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"@sveltejs/kit": "^2.49.1"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@inlang/paraglide-js": "^2.8.0",
		"@playwright/test": "^1.57.0",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.0.15",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"playwright": "^1.57.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"publint": "^0.3.15",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite": "^7.2.6",
		"vitest": "^4.0.15",
		"vitest-browser-svelte": "^2.0.1"
	},
	"keywords": [
		"svelte"
	],
	"dependencies": {
		"@types/bun": "^1.3.10",
		"@vanilla-extract/css": "^1.18.0",
		"@vanilla-extract/recipes": "^0.5.7",
		"@vanilla-extract/vite-plugin": "^5.1.4"
	}
}
